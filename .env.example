# --- KirpichMusic backend env (пример) ---
ENV=dev                          # dev | prod (в prod CookieSecure=true)
HTTP_ADDR=:8080
DATABASE_URL=postgres://kirpich:kirpich@127.0.0.1:5432/kirpichmusic?sslmode=disable

SESSION_TTL=720h                 # 30 суток
SESSION_COOKIE=km_sid
# COOKIE_DOMAIN=                # оставить пустым для localhost

MEDIA_ROOT=./media               # для ШАГА 3 (audio/cover файлы)
MAX_UPLOAD_MB=100
WEB_ROOT=./web                   # папка со статикой фронтенда (index.html)
